{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/WUAIBING/MEP-spec/schemas/node-registration-v1.schema.json",
  "title": "MEP Node Registration v1",
  "type": "object",
  "required": ["node_id", "capabilities", "connectivity"],
  "additionalProperties": true,
  "properties": {
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "alias": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "platform": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "connectivity": {
      "type": "object",
      "required": ["mode"],
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["websocket", "webhook", "long_poll", "human_adapter"]
        },
        "webhook_url": {
          "type": "string",
          "format": "uri"
        },
        "webhook_secret": {
          "type": "string",
          "minLength": 32
        },
        "fallback_mode": {
          "type": "string",
          "enum": ["long_poll", "none"]
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "auto_bid_policy": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "intent_types": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "minimum": 1
        },
        "min_bounty_quanta": {
          "type": "integer",
          "minimum": 0
        },
        "max_task_instructions_length": {
          "type": "integer",
          "minimum": 1
        },
        "availability_schedule": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "timezone": {
              "type": "string",
              "minLength": 1
            },
            "active_hours": {
              "type": "string",
              "pattern": "^\\d{2}:\\d{2}-\\d{2}:\\d{2}$"
            }
          }
        }
      }
    }
  }
}
